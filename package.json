{
  "name": "no-comment-stc-client",
  "version": "0.4.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:dev": "wrangler dev",
    "web:deploy": "wrangler deploy",
    "worker:types": "wrangler types",
    "test": "node --test worker/*.test.mjs",
    "typecheck": "tsc --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "secret-scan": "secretlint \"**/*\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.7",
    "expo-constants": "^57.0.6",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "^0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/react": "~19.2.4",
    "secretlint": "^13.0.2",
    "typescript": "~6.0.3",
    "wrangler": "^4.112.0"
  }
}
